<!DOCTYPE html>
<html lang="en">
<head>
    @inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_Commerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_Commerce.styles.css" asp-append-version="true" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg" style="background-color: #fff0f5; font-family: 'Poppins', sans-serif; font-size: 14px;">
            <div class="container-fluid">
                <!-- Hamburger Toggler -->
              

                <button class="navbar-toggler border border-white p-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown"
                        aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="text-black fs-4">☰</span> <!-- Custom Hamburger Menu -->
                </button>


                <!-- Logo -->
                <div class="mx-auto text-center">
                    <a class="navbar-brand fw-bold text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="https://w7.pngwing.com/pngs/384/470/png-transparent-retail-computer-icons-e-commerce-sales-mega-offer-miscellaneous-service-logo.png"
                             alt="Logo" style="width: 35px; height: auto;">
                        Shopify
                    </a>
                </div>

                <!-- Collapsible Menu -->
                <div class="collapse navbar-collapse justify-content-between" id="navbarNavDropdown">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark nav-hover" asp-controller="Home" asp-action="Index"> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark nav-hover" asp-controller= "Home"asp-action="Index"> About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark nav-hover" asp-controller="Home" asp-action="Privacy"> Privacy</a>
                        </li>
                    </ul>

                    <!-- Switch Role / Login Button -->
                    @{
                        var token = Context.Request.Cookies["TestToken"];
                        var role = Context.Request.Cookies["Role"];
                    }

                    <ul class="navbar-nav">
                        @if (!string.IsNullOrEmpty(token))
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary px-3" asp-controller="User" asp-action="Changerole">
                                    @if (role == "Buyer")
                                    {
                                        <span> Switch to Seller</span>
                                    }
                                    else
                                    {
                                        <span>Switch to Buyer</span>
                                    }
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-primary px-3" asp-controller="User" asp-action="Login">
                                    🔑 Login
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <style>
            /* Navbar Hover Effect */
            .nav-hover {
                position: relative;
                text-decoration: none;
                font-weight: 500;
            }

                .nav-hover::after {
                    content: "";
                    position: absolute;
                    width: 0;
                    height: 2px;
                    background-color: black;
                    bottom: 0;
                    left: 50%;
                    transition: all 0.3s ease;
                }

                .nav-hover:hover::after {
                    width: 100%;
                    left: 0;
                }

            /* Reduce Navbar Height */
            .navbar {
                padding: 8px 12px;
            }
        </style>

    </header>
    <body style="background-color: #fff0f5;">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </body>


    <footer class="border-top footer text-muted py-3" style="background-color: white;">
        <div class="container d-flex flex-column align-items-center">
            <!-- Copyright -->
            <div class=""mt-4>
                &copy; 2025 - E_Commerce -
                <a class="text-decoration-none text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
